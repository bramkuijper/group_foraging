Not sure this works,
 as an individual has only half of twice as many eggs it now needs to take care of,
 but it does not know which half...
\end_layout

\end_inset


\end_layout

\begin_layout Paragraph
Event 3:
 the 
\begin_inset Formula $y_{2}$
\end_inset

 individual forages and survives,
 the 
\begin_inset Formula $y_{1}$
\end_inset

 individual stays home
\begin_inset Formula 
\begin{align*}
W_{3}\left(x\left(t\right),t\right) & =\left[1-f\left(y_{1},x(t)\right)\right]f\left(y_{2},x(t)\right)\left(1-p_{\mathrm{f}}\right)\left(1-p_{h}\left(1\right)\right)\frac{1}{2}\left[\lambda\left(y_{2}\right)W\left(x^{\prime}\left(t+1\right),t+1\right)+\left(1-\lambda\left(y_{2}\right)\right)W\left(x^{\prime\prime}\left(t+1\right),t+1\right)\right],
\end{align*}

\end_inset


\end_layout

\begin_layout Paragraph
Event 4:
 the 
\begin_inset Formula $y_{2}$
\end_inset

 individual forages and dies during foraging,
 the 
\begin_inset Formula $y_{1}$
\end_inset

 individual stays home
\begin_inset Formula 
\begin{align*}
W_{4}\left(x\left(t\right),t\right) & =\left[1-f\left(y_{1},x(t)\right)\right]f\left(y_{2},x(t)\right)p_{\mathrm{f}}\left(1-p_{h}\left(1\right)\right)\frac{1}{2}V\left(x^{\prime\prime}\left(t+1\right),t+1\right),
\end{align*}

\end_inset

Event 5:
 the 
\begin_inset Formula $y_{1}$
\end_inset

 individual forages,
 the 
\begin_inset Formula $y_{2}$
\end_inset

 individual stays home
\begin_inset Formula 
\begin{align*}
W_{5}\left(x\left(t\right),t\right) & =f\left(y_{1},x(t)\right)\left[1-f\left(y_{2},x(t)\right)\right]p_{\mathrm{f}}\left(1-p_{h}\left(1\right)\right)\frac{1}{2}\left[\lambda\left(y_{1}\right)W\left(x^{\prime}\left(t+1\right),t+1\right)+\left(1-\lambda\left(y_{1}\right)\right)W\left(x^{\prime\prime}\left(t+1\right),t+1\right)\right],
\end{align*}

\end_inset


\end_layout

\begin_layout Paragraph
Event 6:
 the 
\begin_inset Formula $y_{1}$
\end_inset

 individual forages,
 the 
\begin_inset Formula $y_{2}$
\end_inset

 individual stays home,
 the 
\begin_inset Formula $y_{1}$
\end_inset

individual dies
\end_layout

\begin_layout Standard
We have
\begin_inset Formula 
\begin{align*}
W_{6}\left(x\left(t\right),t\right) & =f\left(y_{1},x(t)\right)\left[1-f\left(y_{2},x(t)\right)\right]\left(1-p_{\mathrm{f}}\right)\left(1-p_{h}\left(1\right)\right)\frac{1}{2}U\left(x^{\prime\prime}\left(t+1\right),t+1\right).
\end{align*}

\end_inset


\end_layout

\begin_layout Paragraph
Event 7:
 both the 
\begin_inset Formula $y_{1}$
\end_inset

 and 
\begin_inset Formula $y_{2}$
\end_inset

 individuals stay home
\begin_inset Formula 
\begin{align*}
W_{7}\left(x\left(t\right),t\right) & =\left(1-f\left(y_{1},x\left(t\right)\right)\right)\left(1-f\left(y_{2},x\left(t\right)\right)\right)\left(1-p_{h}\left(2\right)\right)W\left(x^{\prime\prime}\left(t+1\right),t+1\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Individuals when alone
\end_layout

\begin_layout Standard
Event 
\begin_inset Formula $1$
\end_inset

,
 
\begin_inset Formula $y_{1}$
\end_inset

 individual goes out to forage
\begin_inset Formula 
\begin{align*}
V_{1}\left(x\left(t\right),t\right) & =f\left(y_{1},x\left(t\right)\right)
\end{align*}

\end_inset


\end_layout

